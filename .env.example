# ─── Client-side (exposed to the browser via Vite) ───────────────────────────
# Get these from your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Base URL of the API server (leave empty when using `vercel dev`, which serves
# both the frontend and the /api/* functions on the same origin at port 3000).
# Set this only if the API runs on a different port/host during development.
VITE_API_BASE_URL=

# ─── Server-side only (never expose these to the browser) ────────────────────
# Supabase service-role key — grants admin access; keep it secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# Default AI model served when the client doesn't specify one.
# Use a free model to keep costs low, e.g.:
#   meta-llama/llama-3.1-8b-instruct:free
#   mistralai/mistral-7b-instruct:free
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Public URL of your deployed site (sent as HTTP-Referer to OpenRouter)
PUBLIC_SITE_URL=https://your-app.vercel.app